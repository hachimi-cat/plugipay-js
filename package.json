{
  "name": "@forjio/plugipay-js",
  "version": "0.1.2",
  "description": "Browser SDK for Plugipay — embedded checkout widget. Renders the payment UI inline on the merchant's storefront.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/index.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "payments",
    "plugipay",
    "forjio",
    "checkout",
    "embedded",
    "browser"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hachimi-cat/plugipay-js.git"
  },
  "bugs": {
    "url": "https://github.com/hachimi-cat/plugipay-js/issues"
  },
  "homepage": "https://github.com/hachimi-cat/plugipay-js#readme"
}
